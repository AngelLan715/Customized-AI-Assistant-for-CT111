PORT=3000
SESSION_SECRET=replace-with-a-long-random-string-use-openssl-or-node-crypto
BASE_URL=http://localhost:3000

# Cloud database (PostgreSQL): Supabase, Neon, Railway, etc.
# Leave unset to use local data/store.json instead.
#
# Supabase: Project Settings → Database → Connection string → URI
# Format (replace YOUR_PASSWORD with the database password from Supabase):
# postgresql://postgres:YOUR_PASSWORD@db.tepidrgaretejduhnqgu.supabase.co:5432/postgres
#
# Note: host is db.<project-ref>.supabase.co — port 5432 — database postgres — user postgres
DATABASE_URL=

# Set to false only for local Postgres without TLS (Supabase needs TLS; leave unset).
DATABASE_SSL=

# AI (OpenAI only): text uses OPENAI_TEXT_MODEL (default gpt-4o-mini), images use OPENAI_IMAGE_MODEL (default gpt-image-1).
# Optional: published dashboard prompt (pmpt_...). If set, text uses /v1/responses with that prompt instead of inline system+user messages.
# OPENAI_TEXT_PROMPT_VARIABLE must match a {{variable}} name in that prompt (default: input).
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=
OPENAI_TEXT_PROMPT_ID=
OPENAI_TEXT_PROMPT_VARIABLE=
OPENAI_IMAGE_MODEL=

# Optional: send sign-in links and welcome emails (leave empty to log links in the console in development)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Core9 AI <noreply@example.com>"
